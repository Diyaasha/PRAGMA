# ─── Copy this file to .env and fill in your values ──────────────────────────
# NEVER commit .env to git

# ─── Database ─────────────────────────────────────────────────────────────────
# Local development:
DATABASE_URL=sqlite:///./pragma_demo.db
# Railway (after mounting a volume at /data):
# DATABASE_URL=sqlite:////data/pragma.db

# ─── Ollama (local LLM — optional, falls back to rule-based extractor) ────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# ─── CORS (comma-separated extra origins — set in Railway/Render to your frontend URL) ──
# CORS_ORIGINS=https://your-frontend.vercel.app,https://pragma.yourdomain.com
